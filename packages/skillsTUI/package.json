{
  "name": "skillstui",
  "version": "0.2.0",
  "type": "module",
  "description": "TUI for discovering and installing AI agent skills from the Open Agent Skills Ecosystem",
  "keywords": [
    "tui",
    "cli",
    "skills",
    "ai",
    "agents",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "terminal",
    "interactive",
    "skills.sh"
  ],
  "main": "./dist/index.js",
  "bin": {
    "skillstui": "dist/index.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "bun run build",
    "start": "node dist/index.js",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18",
    "tsup": "^8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ink": "^5",
    "ink-scroll-list": "^0.4.1",
    "ink-spinner": "^5",
    "ink-text-input": "^6",
    "react": "^18"
  }
}
